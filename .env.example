# ─────────────────────────────────────────────
#  ClaudeTrack — Environment Variables
#  Copy this file to .env and fill in the values
#  cp .env.example .env
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Docker Compose sets this automatically — only change if using an external DB
DATABASE_URL=postgresql://claudetrack:claudetrack@db:5432/claudetrack

# Random secret used to sign sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=replace_me_with_a_random_32_char_string

# Optional: Node environment (development | production)
NODE_ENV=production

# Optional: Port to run the server on (default: 5000)
PORT=5000

# Optional: Encryption key for stored Anthropic API keys (AES-256-GCM)
# Auto-generated from SESSION_SECRET if not set. Set explicitly for key rotation.
# ENCRYPTION_KEY=
